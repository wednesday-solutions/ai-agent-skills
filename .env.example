# Wednesday Agent Skills — Environment Variables
#
# Option 1 — local .env (per project)
#   Place this file at your project root as .env
#   ws-skills will load it automatically from wherever you run the command
#
# Option 2 — shell profile (global, all terminals)
#   Add to ~/.zshrc or ~/.bashrc:
#     export OPENROUTER_API_KEY=sk-or-...
#     export GITHUB_TOKEN=ghp_...
#   Then: source ~/.zshrc
#
# Option 3 — global ~/.wednesday/.env (shared across projects)
#   Create ~/.wednesday/.env with the same key=value format
#
# .env is gitignored — never commit it.
# For GitHub Actions (triage), add keys as repo secrets instead.

# OpenRouter API key (required for plan + triage)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# GitHub token (required for dashboard PR panel, optional locally)
# Fine-grained token needs: repo:read, pull_requests:read
GITHUB_TOKEN=
